# CBS dataset — download from https://www.bis.org/cbspeeches/ or obtain from author
CBS_dataset_v1.0.rds

# ─── Generated Data (regenerated by running the pipeline) ─────────────────────
data/processed/
data/market/

# ─── Generated CSV files in notebooks (keep sovereign_bond_yields & global_cb) ─
notebooks/stooq.csv
notebooks/stooq_backup.csv
notebooks/coverage_report.csv

# ─── Model Artifacts (generated by Phase 3 on Colab) ──────────────────────────
*.pt
*.npy
*.h5
*.hdf5
models/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# ─── Jupyter Notebook checkpoints ─────────────────────────────────────────────
.ipynb_checkpoints/

# ─── Virtual Environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Experiment Tracking ──────────────────────────────────────────────────────
mlruns/
wandb/

# ─── DVC (if used later) ──────────────────────────────────────────────────────
/storage
*.dvc

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
*.tmp
